{
  "name": "Chongban",
  "version": "1.0.0",
  "private": true,
  "description": "瀹犱即妗岄潰瀹犵墿搴旂敤銆?,
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "test": "node --test \"test/**/*.test.cjs\"",
    "prepare:runtime-assets": "powershell -ExecutionPolicy Bypass -File prepare-runtime-assets.ps1",
    "package:win": "powershell -ExecutionPolicy Bypass -File build-electron-win.ps1",
    "installer:win": "powershell -ExecutionPolicy Bypass -File build-installer-win.ps1",
    "pack:win": "npm run prepare:runtime-assets && electron-builder --win dir --x64",
    "package:mac": "npm run prepare:runtime-assets && electron-packager . Chongban --platform=darwin --arch=x64,arm64 --out=release --overwrite --asar --ignore=\"^/(\\.runtime-assets|\\.npm-cache|\\.electron-cache|\\.electron-builder-cache|logs|release|installer)$\" --extra-resource=\".runtime-assets\" --extra-resource=\"../appIcon.ico\""
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.0.0"
  },
  "build": {
    "appId": "com.chongban.desktoppet",
    "productName": "瀹犱即",
    "executableName": "瀹犱即 1.0",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "installer"
    },
    "files": [
      "electron/**/*",
      "static/**/*",
      ".runtime-assets/**/*",
      "package.json",
      "!release/**/*",
      "!cat_release/**/*",
      "!shorthair_release/**/*",
      "!installer/**/*",
      "!cat_installer/**/*",
      "!shorthair_installer/**/*",
      "!logs/**/*",
      "!user-data/**/*",
      "!.user-data/**/*",
      "!.electron-cache/**/*",
      "!.electron-builder-cache/**/*",
      "!.npm-cache/**/*"
    ],
    "extraResources": [
      {
        "from": "build/app_icon.ico",
        "to": "app_icon.ico"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/app_icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "瀹犱即 1.0.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "瀹犱即 1.0",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/app_icon.ico",
      "uninstallerIcon": "build/app_icon.ico",
      "artifactName": "瀹犱即 1.0.${ext}",
      "uninstallDisplayName": "瀹犱即 1.0",
      "include": "build/installer.nsh"
    }
  }
}

