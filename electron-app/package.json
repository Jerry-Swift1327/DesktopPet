{
  "name": "Chongban",
  "version": "1.0.0",
  "private": true,
  "description": "宠伴桌面宠物应用。",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "devtools": "electron devtools/main.cjs",
    "test": "node --test \"test/**/*.test.cjs\"",
    "prepare:runtime-assets": "node prepare-runtime-assets.cjs",
    "package:win": "powershell -ExecutionPolicy Bypass -File build-electron-win.ps1",
    "installer:win": "powershell -ExecutionPolicy Bypass -File build-installer-win.ps1",
    "pack:win": "npm run prepare:runtime-assets && electron-builder --win dir --x64 && node scripts/prune-packaged-runtime.cjs --root installer/win-unpacked",
    "package:mac": "node build-installer-mac.cjs",
    "installer:mac": "node build-installer-mac.cjs",
    "variant": "node scripts/variant-cli.cjs",
    "variant:list": "node scripts/variant-cli.cjs list",
    "variant:show": "node scripts/variant-cli.cjs show",
    "variant:query": "node scripts/variant-cli.cjs query",
    "variant:new": "node scripts/variant-cli.cjs new",
    "variant:bootstrap": "node scripts/variant-cli.cjs bootstrap",
    "variant:check": "node scripts/variant-cli.cjs check",
    "variant:rename-assets": "node scripts/variant-cli.cjs rename-assets",
    "variant:gallery": "node scripts/variant-cli.cjs gallery",
    "variant:species": "node scripts/variant-cli.cjs species",
    "variant:tiers": "node scripts/variant-cli.cjs tiers"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.0.0"
  },
  "build": {
    "appId": "com.chongban.desktoppet",
    "productName": "宠伴",
    "executableName": "宠伴 1.0",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "installer"
    },
    "files": [
      "electron/**/*",
      "static/**/*",
      ".runtime-assets/**/*",
      "package.json",
      "!release/**/*",
      "!cat_release/**/*",
      "!shorthair_release/**/*",
      "!installer/**/*",
      "!cat_installer/**/*",
      "!shorthair_installer/**/*",
      "!mac_installer/**/*",
      "!deliverables/**/*",
      "!logs/**/*",
      "!user-data/**/*",
      "!.user-data/**/*",
      "!.electron-cache/**/*",
      "!.electron-builder-cache/**/*",
      "!.npm-cache/**/*"
    ],
    "extraResources": [
      {
        "from": "build/app_icon.ico",
        "to": "app_icon.ico"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/app_icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "宠伴 1.0.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "宠伴 1.0",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/app_icon.ico",
      "uninstallerIcon": "build/app_icon.ico",
      "artifactName": "宠伴 1.0.${ext}",
      "uninstallDisplayName": "宠伴 1.0",
      "include": "build/installer.nsh"
    }
  }
}

